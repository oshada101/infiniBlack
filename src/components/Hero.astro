<section id="hero" class="relative" aria-label="Intro">
  <!-- skip control, only visible while the boot plays -->
  <button
    id="intro-skip"
    type="button"
    class="label-mono invisible fixed right-8 top-24 z-40 cursor-pointer rounded-full border border-line bg-ink px-4 py-2.5 opacity-0 transition-colors hover:border-acid hover:text-acid active:border-acid lg:top-8"
  >
    skip ↳
  </button>

  <div class="flex flex-col gap-4 lg:min-h-[calc(100svh-2rem)]">
    <!-- headline card -->
    <div
      class="card card-acid draft-grid-dark relative flex min-h-[58svh] flex-col justify-between gap-12 overflow-hidden p-7 md:p-12"
      data-piece="left"
    >
      <p class="label-mono">00 — Infini Black · AI studio</p>

      <h1 class="heading text-[11.5vw] sm:text-6xl md:text-7xl xl:text-[5.6rem]">
        <span class="block"><span data-typein>We build systems</span></span>
        <span class="block"><span data-typein>that build</span></span>
        <span class="block"><span data-typein>themselves.</span><span class="caret" aria-hidden="true"></span></span>
      </h1>

      <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
        <p class="max-w-md text-base font-medium text-ink/70 md:text-lg">
          AI systems, automation, websites and apps — designed, assembled and
          shipped by a studio that automates its own work first.
        </p>
        <a
          href="#contact"
          data-flicker
          class="label-mono inline-flex w-fit shrink-0 items-center gap-3 rounded-full bg-ink px-7 py-4 !text-paper no-underline hover:scale-[1.03] active:scale-[0.98]"
        >
          Start a build <span class="text-acid">↳</span>
        </a>
      </div>
    </div>

    <!-- ribbon image card -->
    <div
      class="card card-dark relative min-h-[26svh] flex-1 overflow-hidden"
      data-piece="up"
    >
      <img
        src="/hero-ribbon.webp"
        alt=""
        class="absolute inset-0 h-full w-full object-cover object-left"
        loading="eager"
        decoding="async"
      />
      <p class="label-mono absolute bottom-5 right-6 z-10 text-paper/50">∞ / continuous build</p>
    </div>
  </div>
</section>

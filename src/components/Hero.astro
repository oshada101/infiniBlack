---
const stats = [
  { n: '24', suf: '+', label: 'systems shipped' },
  { n: '18k', suf: '+', label: 'hours automated / yr' },
  { n: '100', suf: '%', label: 'built in-house' },
];
---

<section id="hero" class="relative flex min-h-svh flex-col justify-end overflow-hidden pt-14" aria-label="Intro">
  <!-- blueprint grid, fades to faint after intro -->
  <div class="draft-grid pointer-events-none absolute inset-0 opacity-50" aria-hidden="true"></div>

  <!-- skip control, only visible while the intro plays -->
  <button
    id="intro-skip"
    type="button"
    class="label-mono invisible fixed right-5 top-16 z-40 cursor-pointer border border-line bg-ink px-3 py-2 opacity-0 transition-colors hover:border-acid hover:text-acid active:border-acid md:right-8"
  >
    skip ↳
  </button>

  <!-- system schematic — assembles during intro, wires stay live after -->
  <div
    id="schematic"
    class="pointer-events-none absolute right-4 top-20 w-[210px] opacity-90 sm:w-[260px] md:right-8 md:top-32 md:w-[340px]"
    aria-hidden="true"
  >
    <svg viewBox="0 0 420 260" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <polyline id="w1" class="wire" points="112,22 210,22 210,100" />
      <polyline id="w2" class="wire" points="112,230 210,230 210,156" />
      <polyline id="w3" class="wire" points="270,120 359,120 359,42" />
      <polyline id="w4" class="wire" points="270,136 359,136 359,210" />

      <g class="node" id="n-brief">
        <rect x="2" y="2" width="110" height="40" stroke="rgba(244,244,242,0.3)" />
        <text x="16" y="26" fill="rgba(244,244,242,0.6)" font-size="9" letter-spacing="2" font-family="Martian Mono Variable, monospace">BRIEF</text>
      </g>
      <g class="node" id="n-data">
        <rect x="2" y="210" width="110" height="40" stroke="rgba(244,244,242,0.3)" />
        <text x="16" y="234" fill="rgba(244,244,242,0.6)" font-size="9" letter-spacing="2" font-family="Martian Mono Variable, monospace">DATA</text>
      </g>
      <g class="node" id="n-core">
        <rect x="150" y="100" width="120" height="56" stroke="#B4FF39" stroke-opacity="0.85" />
        <text x="166" y="132" fill="#B4FF39" font-size="10" letter-spacing="2" font-family="Martian Mono Variable, monospace">∞ CORE</text>
      </g>
      <g class="node" id="n-agents">
        <rect x="300" y="2" width="118" height="40" stroke="rgba(244,244,242,0.3)" />
        <text x="314" y="26" fill="rgba(244,244,242,0.6)" font-size="9" letter-spacing="2" font-family="Martian Mono Variable, monospace">AGENTS</text>
      </g>
      <g class="node" id="n-ship">
        <rect x="300" y="210" width="118" height="40" stroke="rgba(244,244,242,0.3)" />
        <text x="314" y="234" fill="rgba(244,244,242,0.6)" font-size="9" letter-spacing="2" font-family="Martian Mono Variable, monospace">SHIP</text>
      </g>

      <circle id="pulse1" cx="112" cy="22" r="2.5" fill="#B4FF39" opacity="0" />
      <circle id="pulse2" cx="270" cy="136" r="2.5" fill="#B4FF39" opacity="0" />
    </svg>
  </div>

  <div class="hero-parallax relative mx-auto w-full max-w-6xl px-5 pb-14 md:px-8 md:pb-16">
    <p class="label-mono mb-6" data-piece="left">00 — Infini Black · AI studio</p>

    <h1 class="heading text-[13.5vw] leading-[0.95] sm:text-7xl md:text-8xl lg:text-9xl">
      <span class="block" data-piece="left"><span data-typein>We build systems</span></span>
      <span class="block" data-piece="right"><span data-typein>that build</span></span>
      <span class="block" data-piece="left"
        ><span data-typein>themselves.</span><span class="caret" aria-hidden="true"></span></span
      >
    </h1>

    <div class="mt-10 flex flex-col gap-8 md:mt-12 md:flex-row md:items-end md:justify-between">
      <p class="max-w-md text-base text-dim md:text-lg" data-piece="up">
        AI systems, automation, websites and apps — designed, assembled and shipped
        by a studio that automates its own work first.
      </p>

      <a
        href="#contact"
        data-piece="up"
        data-flicker
        class="label-mono draft-corners inline-flex w-fit items-center gap-3 border border-line px-6 py-4 text-paper transition-colors hover:border-acid hover:text-acid active:border-acid"
      >
        Start a build <span class="text-acid">↳</span>
      </a>
    </div>

    <div class="draft-rule mt-10 md:mt-14" data-piece="scale"></div>

    <div class="mt-5 flex items-end justify-between gap-6" data-piece="up">
      <div class="flex gap-10 md:gap-16">
        {
          stats.map(({ n, suf, label }) => (
            <div>
              <p class="heading text-2xl md:text-4xl">
                {n}<span class="text-acid">{suf}</span>
              </p>
              <p class="label-mono mt-1.5">{label}</p>
            </div>
          ))
        }
      </div>
      <p class="label-mono hidden text-acid sm:block" aria-hidden="true">scroll ▼</p>
    </div>
  </div>
</section>

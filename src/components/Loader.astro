---

<!-- boot screen — only rendered visible when html.js is set; assembly.ts drives it -->
<div id="loader" class="flex-col items-center justify-center gap-10 px-6" aria-hidden="true">
  <p class="heading text-lg tracking-tight text-paper sm:text-xl">
    INFINI<span class="text-acid">/</span>BLACK
  </p>

  <div class="w-full max-w-xs">
    <div class="flex items-baseline justify-between">
      <p id="loader-log" class="label-mono h-4 normal-case tracking-[0.08em]">&gt; init</p>
      <p id="loader-pct" class="label-mono text-acid">0%</p>
    </div>
    <div class="mt-3 h-px w-full bg-line">
      <div id="loader-bar" class="h-px w-full bg-acid"></div>
    </div>
  </div>
</div>

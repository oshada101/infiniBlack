---
const services = [
  {
    index: "S/01",
    title: "AI Systems",
    desc: "Custom LLM-powered products, agents, retrieval and evals. Built to reason on your data, not a demo.",
  },
  {
    index: "S/02",
    title: "Automation",
    desc: "Pipelines that remove manual work end-to-end. Fewer handoffs, fewer humans in the loop.",
  },
  {
    index: "S/03",
    title: "Websites",
    desc: "Fast, precise marketing and product sites. Built for conversion, not decoration.",
  },
  {
    index: "S/04",
    title: "Apps",
    desc: "Web and mobile products, shipped production-grade. From first commit to first user.",
  },
];
---

<section id="services" class="relative overflow-hidden border-t border-line" data-assemble aria-label="Services">
  <div class="ghost-num" aria-hidden="true">01</div>
  <div class="relative z-10 mx-auto max-w-6xl px-5 py-24 md:px-8 md:py-32">
    <p class="label-mono" data-piece="left">01 — Services</p>

    <h2 class="heading mt-6 text-4xl md:text-6xl">
      <span data-typein>What we assemble.</span>
    </h2>

    <div class="mt-14 grid grid-cols-1 gap-px border border-line bg-line md:mt-20 md:grid-cols-2">
      {
        services.map((service) => (
          <article
            data-piece
            data-flicker
            class="draft-corners group bg-ink p-6 transition-colors hover:bg-acid/[0.03] active:bg-acid/[0.03] md:p-10"
          >
            <p class="label-mono text-acid/60 transition-colors group-hover:text-acid group-active:text-acid">
              {service.index}
            </p>
            <h3 class="heading mt-5 text-2xl text-paper md:text-3xl">{service.title}</h3>
            <p class="mt-4 max-w-sm text-sm text-dim md:text-base">{service.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

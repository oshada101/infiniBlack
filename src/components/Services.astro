---
const services = [
  {
    index: "S/02",
    title: "Automation",
    desc: "Pipelines removing manual work end-to-end.",
  },
  {
    index: "S/03",
    title: "Websites",
    desc: "Fast, precise marketing and product sites.",
  },
  {
    index: "S/04",
    title: "Apps",
    desc: "Web and mobile, shipped production-grade.",
  },
];
---

<section id="services" class="relative" data-assemble aria-label="Services">
  <p class="label-mono" data-piece="left">01 — Services</p>

  <h2 class="heading mt-4 text-4xl md:text-6xl">
    <span data-typein>What we assemble.</span>
  </h2>

  <div class="mb-8 grid grid-cols-1 gap-4 mt-8 md:mb-10 md:mt-10 md:grid-cols-2">
    <article
      data-piece="scale"
      data-flicker
      class="card card-acid flex flex-col justify-between p-7 md:min-h-[300px] md:p-10"
    >
      <div class="flex items-start justify-between">
        <p class="label-mono">S/01</p>
        <span aria-hidden="true">↗</span>
      </div>
      <div>
        <h3 class="heading text-3xl md:text-4xl">AI Systems</h3>
        <p class="mt-4 max-w-sm text-sm text-ink/70 md:text-base">
          Custom LLM products, agents, retrieval, evals — reasoning on your data, not a demo.
        </p>
      </div>
    </article>

    {
      services.map((service, i) => (
        <article
          data-piece={i === 0 ? "left" : i === 1 ? "up" : "right"}
          data-flicker
          class="card card-dark flex flex-col justify-between p-7 md:p-10"
        >
          <div class="flex items-start justify-between">
            <p class="label-mono">{service.index}</p>
            <span class="text-acid" aria-hidden="true">↗</span>
          </div>
          <div>
            <h3 class="heading text-3xl md:text-4xl">{service.title}</h3>
            <p class="mt-4 max-w-sm text-sm text-dim md:text-base">{service.desc}</p>
          </div>
        </article>
      ))
    }
  </div>
</section>

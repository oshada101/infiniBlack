---
const year = new Date().getFullYear();
// grid cells that "assembled themselves" — aligned to the 72px draft grid
const cells = [
  { top: 1, left: 4, acid: true },
  { top: 3, left: 11, acid: true },
  { top: 2, left: 8, acid: false },
  { top: 4, left: 2, acid: false },
];
---

<footer class="px-4 pb-4 pt-0 lg:pl-[12rem]">
  <div class="card card-dark draft-grid relative overflow-hidden p-7 md:p-10">
    {
      cells.map(({ top, left, acid }) => (
        <div
          class:list={['absolute h-[72px] w-[72px]', acid ? 'bg-acid/70' : 'bg-paper/10']}
          style={`top:${top * 72}px;left:${left * 72}px`}
          aria-hidden="true"
        />
      ))
    }

    <div class="relative z-10 flex flex-wrap items-center justify-between gap-4">
      <a
        href="mailto:hello@infiniblack.com"
        data-flicker
        class="label-mono rounded-full bg-acid px-6 py-3.5 !text-ink no-underline transition-transform hover:scale-[1.03] active:scale-[0.98]"
      >
        hello@infiniblack.com ↳
      </a>
      <div class="flex flex-wrap items-center gap-3">
        <button
          type="button"
          data-rebuild
          class="label-mono cursor-pointer rounded-full border border-line px-5 py-3 transition-colors hover:border-acid hover:text-acid active:border-acid"
          aria-label="Replay the intro animation"
        >
          rebuild ↻
        </button>
        <p class="label-mono">© {year} — assembled by its own system</p>
      </div>
    </div>

    <p
      class="heading relative z-10 mt-20 select-none whitespace-nowrap text-[13vw] leading-[0.78] lg:text-[10.5vw]"
      aria-hidden="true"
    >
      INFINI<span class="text-acid">/</span>BLACK
    </p>
  </div>
</footer>

---
const base = import.meta.env.BASE_URL;
---

<section id="work" class="relative" data-assemble aria-label="Selected work">
  <p class="label-mono" data-piece="left">02 — Selected work</p>

  <h2 class="heading mt-4 text-4xl md:text-6xl mb-8 md:mb-10">
    <span data-typein>Built and shipped.</span>
  </h2>

  <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
    <a
      href="/work#glorious"
      data-morph
      data-piece="left"
      class="project-card card card-dark group flex flex-col gap-6 p-5 no-underline md:p-7"
    >
      <div class="project-media aspect-[16/10]" transition:name="media-glorious">
        <video src={`${base}projects/glorious.mp4`} autoplay loop muted playsinline class="h-full w-full object-cover" poster={`${base}projects/glorious.webp`} data-autoplay />
      </div>
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="label-mono text-acid">W/01 — 2025</p>
          <h3 class="heading mt-3 text-2xl md:text-3xl">Glorious Fitness Center</h3>
          <p class="text-dim mt-2">Full marketing site for a fitness center — programs, trainers, memberships.</p>
        </div>
        <span class="badge-shipped shrink-0">Shipped</span>
      </div>
    </a>

    <a
      href="/work#kratos"
      data-morph
      data-piece="right"
      class="project-card card card-dark group flex flex-col gap-6 p-5 no-underline md:p-7"
    >
      <div class="project-media aspect-[16/10]" transition:name="media-kratos">
        <img src={`${base}projects/kratos.png`} alt="Kratos gym management system" loading="lazy" />
      </div>
      <div class="flex items-start justify-between gap-4">
        <div>
          <p class="label-mono text-crimson">W/02 — ongoing</p>
          <h3 class="heading mt-3 text-2xl md:text-3xl">Kratos</h3>
          <p class="text-dim mt-2">Gym management system — members, billing, attendance, one dashboard.</p>
        </div>
        <span class="badge-live shrink-0">In progress</span>
      </div>
    </a>
  </div>

  <a
    href="/work"
    data-piece="up"
    class="nav-item card card-dark mt-4 flex items-center justify-between p-6 no-underline md:p-7"
  >
    <span class="heading text-xl md:text-2xl">All projects</span>
    <span class="label-mono text-acid">↳ /work <span class="nav-arrow inline-block">↗</span></span>
  </a>
</section>

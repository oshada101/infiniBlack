---
export interface Slide {
  src: string;
  alt: string;
}

const { slides, base: baseUrl = import.meta.env.BASE_URL } = Astro.props as {
  slides: Slide[];
  base?: string;
};
---

<div class="slider" data-slider>
  <div class="slider-track" data-slider-track>
    {slides.map((s) => (
      <div class="slider-slide">
        <img src={`${baseUrl}${s.src}`} alt={s.alt} />
      </div>
    ))}
  </div>

  {slides.length > 1 && (
    <>
      <button class="slider-btn slider-btn-prev" data-slider-prev aria-label="Previous slide">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M12 4L6 10L12 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="slider-btn slider-btn-next" data-slider-next aria-label="Next slide">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M8 4L14 10L8 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="slider-dots" data-slider-dots>
        {slides.map((_, i) => (
          <button
            class="slider-dot"
            data-slider-dot={i}
            aria-label={`Slide ${i + 1}`}
          ></button>
        ))}
      </div>
    </>
  )}

  <script is:inline>
    const root = document.currentScript?.closest('[data-slider]');
    if (!root) throw new Error('ImageSlider: no root');

    const track = root.querySelector('[data-slider-track]');
    const slides = track?.querySelectorAll('.slider-slide');
    const prevBtn = root.querySelector('[data-slider-prev]');
    const nextBtn = root.querySelector('[data-slider-next]');
    const dots = root.querySelectorAll('[data-slider-dot]');

    let current = 0;

    function goTo(index) {
      if (!track || !slides) return;
      if (index < 0) index = slides.length - 1;
      if (index >= slides.length) index = 0;
      current = index;
      track.style.transform = 'translateX(-' + (current * 100) + '%)';
      dots.forEach((dot, i) => {
        if (i === current) {
          dot.setAttribute('data-active', '');
        } else {
          dot.removeAttribute('data-active');
        }
      });
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot) => {
      dot.addEventListener('click', () => goTo(Number(dot.dataset.sliderDot)));
    });
  </script>
</div>

<style>
  .slider {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  .slider-track {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .slider-slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
  }
  .slider-slide img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .slider-btn {
    position: absolute;
    top: 50%;
    z-index: 10;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid rgba(244, 244, 242, 0.15);
    background: rgba(0, 0, 0, 0.55);
    color: rgba(244, 244, 242, 0.85);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.3s, background 0.3s, transform 0.3s;
    backdrop-filter: blur(4px);
  }
  .slider:hover .slider-btn {
    opacity: 1;
  }
  .slider-btn:hover {
    background: rgba(0, 0, 0, 0.8);
    color: var(--color-acid, #b4ff39);
  }
  .slider-btn-prev {
    left: 12px;
  }
  .slider-btn-next {
    right: 12px;
  }

  .slider-dots {
    position: absolute;
    bottom: 12px;
    left: 50%;
    z-index: 10;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
  }
  .slider-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    border: none;
    background: rgba(244, 244, 242, 0.35);
    cursor: pointer;
    transition: background 0.3s, transform 0.3s;
    padding: 0;
  }
  .slider-dot[data-active] {
    background: var(--color-acid, #b4ff39);
    transform: scale(1.25);
  }
  .slider-dot:hover {
    background: rgba(244, 244, 242, 0.7);
  }

  @media (prefers-reduced-motion: reduce) {
    .slider-track {
      transition: none;
    }
  }
</style>

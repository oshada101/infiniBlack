---
const links = [
  { href: '#services', label: 'Services', n: '01' },
  { href: '#work', label: 'Work', n: '02' },
  { href: '#process', label: 'Process', n: '03' },
  { href: '#contact', label: 'Contact', n: '04' },
];
---

<header id="site-nav">
  <!-- mobile top bar -->
  <div class="card card-dark fixed inset-x-4 top-4 z-50 flex h-14 items-center justify-between px-5 lg:hidden">
    <a href="#top" class="heading text-sm text-paper no-underline" aria-label="Infini Black — home">
      INFINI<span class="text-acid">/</span>BLACK
    </a>
    <button
      id="nav-toggle"
      class="-mr-2 flex h-10 w-10 flex-col items-center justify-center gap-1.5"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-menu"
    >
      <span class="block h-px w-5 bg-paper transition-transform duration-300"></span>
      <span class="block h-px w-5 bg-paper transition-opacity duration-300"></span>
      <span class="block h-px w-5 bg-paper transition-transform duration-300"></span>
    </button>
  </div>

  <!-- mobile menu sheet -->
  <div id="nav-menu" class="card card-dark fixed inset-x-4 top-[4.75rem] z-50 hidden p-3 lg:hidden" hidden>
    <ul class="flex flex-col gap-2">
      {
        links.map(({ href, label, n }) => (
          <li>
            <a
              href={href}
              data-nav-close
              class="card card-dark flex items-center justify-between px-5 py-4 no-underline transition-colors hover:bg-acid hover:text-ink active:bg-acid active:text-ink"
            >
              <span class="heading text-base">{label}</span>
              <span class="label-mono text-acid">{n} ↗</span>
            </a>
          </li>
        ))
      }
      <li>
        <a
          href="#contact"
          data-nav-close
          class="card card-acid flex items-center justify-between px-5 py-4 no-underline"
        >
          <span class="heading text-base">Start a build</span>
          <span class="font-mono text-xs">↳</span>
        </a>
      </li>
    </ul>
  </div>

  <!-- desktop sidebar -->
  <aside class="fixed bottom-4 left-4 top-4 z-50 hidden w-40 flex-col gap-3 lg:flex">
    <a href="#top" class="card card-paper block p-4 no-underline" aria-label="Infini Black — home">
      <span class="heading block text-lg leading-none">INFINI<span class="block">BLACK<span class="text-ink">.</span></span></span>
      <span class="label-mono mt-2 block">AI studio</span>
    </a>

    {
      links.map(({ href, label, n }) => (
        <a
          href={href}
          data-flicker
          class="card card-dark group flex flex-1 flex-col justify-between p-4 no-underline transition-colors hover:bg-acid hover:text-ink active:bg-acid active:text-ink"
        >
          <span class="flex items-center justify-between">
            <span class="label-mono transition-colors group-hover:text-ink/60 group-active:text-ink/60">{n}</span>
            <span class="font-mono text-[10px] text-acid transition-colors group-hover:text-ink group-active:text-ink">↗</span>
          </span>
          <span class="heading text-sm">{label}</span>
        </a>
      ))
    }

    <a
      href="#contact"
      data-flicker
      class="card card-acid flex min-h-20 flex-col justify-between p-4 no-underline"
    >
      <span class="font-mono text-[10px]">↳</span>
      <span class="heading text-sm leading-tight">Start a build</span>
    </a>
  </aside>
</header>

<script>
  const toggle = document.getElementById('nav-toggle')!;
  const menu = document.getElementById('nav-menu')!;
  const bars = toggle.querySelectorAll('span');

  function setOpen(open: boolean) {
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    menu.hidden = !open;
    menu.classList.toggle('hidden', !open);
    bars[0].style.transform = open ? 'translateY(6.5px) rotate(45deg)' : '';
    bars[1].style.opacity = open ? '0' : '1';
    bars[2].style.transform = open ? 'translateY(-6.5px) rotate(-45deg)' : '';
  }

  toggle.addEventListener('click', () => setOpen(menu.hidden));
  menu.querySelectorAll('[data-nav-close]').forEach((a) =>
    a.addEventListener('click', () => setOpen(false)),
  );
</script>

---
const items = ['AI systems', 'Automation', 'Websites', 'Apps', 'Agents', 'Pipelines'];
// track duplicated once; CSS translates -50% for a seamless loop
const track = [...items, ...items];
---

<div class="marquee card card-acid py-3.5" aria-hidden="true">
  <div class="marquee-track">
    {
      track.map((item) => (
        <span class="flex shrink-0 items-center whitespace-nowrap font-mono text-[11px] uppercase tracking-[0.18em]">
          <span class="px-6">{item}</span>
          <span class="opacity-40">◆</span>
        </span>
      ))
    }
  </div>
</div>
